# ============================================================
# Fazle Personal AI System — Environment Variables
# Copy to .env (or add to root .env) and fill in secrets.
# ============================================================

# ── LLM Configuration ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
FAZLE_LLM_PROVIDER=openai        # "openai" or "ollama"
FAZLE_LLM_MODEL=gpt-4o
FAZLE_OLLAMA_MODEL=llama3.1
OLLAMA_URL=http://ollama:11434

# ── Search API ──────────────────────────────────────────────
SERPER_API_KEY=your-serper-api-key
TAVILY_API_KEY=
FAZLE_SEARCH_PROVIDER=serper     # "serper" or "tavily"

# ── Security / Auth ────────────────────────────────────────
FAZLE_API_KEY=                   # 64-char key for service-to-service auth
FAZLE_JWT_SECRET=change-me-in-production-min-32-chars
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars
NEXTAUTH_URL=https://fazle.iamazim.com

# ── Database ───────────────────────────────────────────────
FAZLE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# ── Vector DB ──────────────────────────────────────────────
VECTOR_DB_URL=http://qdrant:6333

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:redissecret@redis:6379/1

# ── LiveKit (Voice) ────────────────────────────────────────
FAZLE_LIVEKIT_API_KEY=
FAZLE_LIVEKIT_API_SECRET=
FAZLE_LIVEKIT_URL=wss://livekit.iamazim.com

# ── Voice Agent ────────────────────────────────────────────
FAZLE_VOICE_TTS_VOICE=alloy     # OpenAI TTS voice: alloy, echo, fable, onyx, nova, shimmer

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=https://fazle.iamazim.com,https://iamazim.com,http://localhost:3020

# ── Social Engine — WhatsApp + Facebook ─────────────────────
# All read by social-engine/main.py via pydantic_settings env_prefix="SOCIAL_"
# Use ONLY these canonical SOCIAL_* names; do not use legacy WHATSAPP_*/FACEBOOK_* names.

# Meta app secret — validates X-Hub-Signature-256 on webhook POST
SOCIAL_META_APP_SECRET=CHANGE_ME_META_APP_SECRET

# WhatsApp Cloud API (Business Platform)
SOCIAL_WHATSAPP_API_URL=https://graph.facebook.com/v19.0
SOCIAL_WHATSAPP_API_TOKEN=CHANGE_ME_WHATSAPP_API_TOKEN
SOCIAL_WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME_PHONE_NUMBER_ID

# Facebook Page
SOCIAL_FACEBOOK_PAGE_ACCESS_TOKEN=CHANGE_ME_FB_PAGE_ACCESS_TOKEN
SOCIAL_FACEBOOK_PAGE_ID=CHANGE_ME_FB_PAGE_ID

# Auto-generated by gen-secrets.sh — REQUIRED before enabling social integration
SOCIAL_ENCRYPTION_KEY=CHANGE_ME_SOCIAL_ENCRYPTION_KEY
SOCIAL_VERIFY_TOKEN=CHANGE_ME_SOCIAL_VERIFY_TOKEN
