# AI Agent Service — Environment Variables
# This service dispatches the existing fazle-voice AI agent
# to LiveKit rooms when Twilio/SIP callers join.

# ── Feature Flags ───────────────────────────────────────────
AI_ENABLED=true

# ── LiveKit ─────────────────────────────────────────────────
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME_MIN_32_CHARS
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_URL=ws://livekit:7880

# ── Redis (DB 2 — separate from voice sessions on DB 1) ────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2

# ── Provider Selection ──────────────────────────────────────
# These configure which providers are reported in status checks.
# Actual processing happens inside fazle-voice.
STT_PROVIDER=whisper       # whisper | deepgram
TTS_PROVIDER=piper         # piper | elevenlabs | openai
LLM_PROVIDER=brain         # brain | openai | ollama

# ── Optional API Keys (for health checks) ──────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
FAZLE_BRAIN_URL=http://fazle-brain:8200

# ── Safety ──────────────────────────────────────────────────
DISPATCH_TIMEOUT_MS=5000
MAX_RESPONSE_TIME_SEC=7
MAX_CONCURRENT_AGENTS=5
